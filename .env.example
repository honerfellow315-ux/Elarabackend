# ---------------------------------------------------------------------------
# ELARAWAVE backend — environment variables
# Copy this file to .env for local dev. On Render, set these under
# Dashboard -> your service -> Environment. NEVER commit a real .env file.
# ---------------------------------------------------------------------------

NODE_ENV=production
PORT=10000

# Supabase Postgres connection string
# Supabase dashboard -> Project Settings -> Database -> Connection string (URI)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
DATABASE_SSL=true

# Two SEPARATE strong random secrets (never reuse). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_USER_SECRET=replace_with_a_64+_char_random_secret
JWT_ADMIN_SECRET=replace_with_a_different_64+_char_random_secret
JWT_USER_EXPIRES_IN=7d
JWT_ADMIN_EXPIRES_IN=12h

# Brevo (Sendinblue) — Settings -> SMTP & API -> API Keys
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=ELARA WAVE

# Comma-separated list of allowed frontend origins (no trailing slash)
FRONTEND_URL=https://your-frontend-domain.com

# Hugging Face Inference API — powers the "Enhance with AI" bottle mockup
# generator on the custom-branding page. Optional: leave blank and that
# one endpoint will return a friendly 503 instead of breaking anything else.
# Get a token at https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=black-forest-labs/FLUX.1-schnell

# Google Places API — pulls the client's REAL Google reviews into the
# "Google Reviews" section (GET /api/reviews). Optional: leave both blank
# and the site just shows site-submitted reviews only, nothing breaks.
# 1. Go to console.cloud.google.com -> create/select a project.
# 2. APIs & Services -> Library -> enable "Places API".
# 3. APIs & Services -> Credentials -> Create Credentials -> API key.
#    Restrict it (API restrictions -> Places API only) so it can't be
#    abused elsewhere if it ever leaks.
# 4. Find the Place ID for the client's business listing here:
#    https://developers.google.com/maps/documentation/places/web-service/place-id
#    (search the exact business name/address, copy the Place ID shown).
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
# How long (minutes) fetched Google reviews are cached before re-fetching.
GOOGLE_REVIEWS_CACHE_MINUTES=60


# Used ONLY once, by `npm run db:seed-admin`, to create/update the admin
# account. Remove them from Render's env after seeding if you want.
ADMIN_USERNAME=adminelarawave
ADMIN_PASSWORD=change_this_before_seeding

# Security tuning (safe defaults, override if needed)
BCRYPT_COST=12
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
